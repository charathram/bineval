# Copy to `.env` and fill in. BinEval loads this file when configuring its LMs.
# (Real process environment variables take precedence over values here.)

# --- Provider API keys (used automatically by the model's provider) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Shared LM config (applies to both roles unless a per-role var overrides it) ---
BINEVAL_MODEL=openai:gpt-4o-mini
# BINEVAL_TEMPERATURE=0.0
# BINEVAL_MAX_TOKENS=4096
# BINEVAL_BASE_URL=           # for OpenAI-compatible / local servers (e.g. vLLM, Ollama)
# BINEVAL_API_KEY=            # explicit key override; else the provider's standard key above is used

# --- Per-role overrides (BinEval uses TWO LMs: a generator and an evaluator) ---
# BINEVAL_GENERATOR_MODEL=anthropic:claude-sonnet-4-5-20250929
# BINEVAL_GENERATOR_MAX_TOKENS=4096
# BINEVAL_EVALUATOR_MODEL=openai:gpt-4o-mini
# BINEVAL_EVALUATOR_MAX_TOKENS=1024

# --- Optional BinEval settings (read by BinEval::from_env) ---
# BINEVAL_DIMENSIONS=coherence,consistency,fluency,relevance
# BINEVAL_CONCURRENCY=8
# BINEVAL_MAX_RETRIES=3
# BINEVAL_STRICT=false
